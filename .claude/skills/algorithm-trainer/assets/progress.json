    { "tag": "[链表] 相邻节点交换", "pattern": "两两交换 → Dummy + 三指针交换 → p0 前进到原 p1", "dateAdded": "2026-04-13" },
    { "tag": "[链表] K 个一组翻转", "pattern": "分组翻转 → 先检查 k 个 → 标准反转 → 缝合 → p0 前进", "dateAdded": "2026-04-13" },
